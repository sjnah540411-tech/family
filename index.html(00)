firebase.initializeApp(firebaseConfig);
const db = firebase.firestore();
const storage = firebase.storage();

let GLOBAL_RECORDS = [];
let GLOBAL_MEMBERS = [];
let CURRENT_USER = null;
let currentEditId = null;

const DECADES = [
  { id:'before1954', label:'1954년 이전' }, { id:'1950s', label:'1950년대' }, { id:'1960s', label:'1960년대' }, { id:'1970s', label:'1970년대' },
  { id:'1980s', label:'1980년대' }, { id:'1990s', label:'1990년대' }, { id:'2000s', label:'2000년대' }, { id:'2010s', label:'2010년대' },
