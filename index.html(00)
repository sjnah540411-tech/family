  { id:'special', label:'⭐ 특별한 날' }, { id:'daily', label:'☀️ 소소한 일상' }
];

function showLoading(show, text='처리 중...') { document.getElementById('loading-text').textContent = text; document.getElementById('loading-overlay').style.display = show ? 'flex' : 'none'; }
function showToast(msg, isErr=false){ let t=document.getElementById('tst'); if(!t){t=document.createElement('div');t.id='tst';t.style.cssText='position:fixed;bottom:30px;left:50%;transform:translateX(-50%);padding:10px 20px;border-radius:20px;color:#fff;z-index:9999;transition:0.3s;';document.body.appendChild(t);} t.style.background=isErr?'var(--rust)':'var(--brown-deep)'; t.textContent=msg; t.style.opacity='1'; setTimeout(()=>t.style.opacity='0', 4000); }

function getDecade(dStr) {
  if(!dStr) return '2020s'; const y = parseInt(dStr.split('-')[0]);
  if(y<=1954) return 'before1954'; if(y<1960) return '1950s'; if(y<1970) return '1960s'; if(y<1980) return '1970s';
  if(y<1990) return '1980s'; if(y<2000) return '1990s'; if(y<2010) return '2000s'; if(y<2020) return '2010s'; if(y<2030) return '2020s'; return '2030s';
}

function initDateSelects() {
  let y='', m='', d='';
  for(let i=new Date().getFullYear(); i>=1920; i--) y+=`<option value="${i}">${i}년</option>`;
  for(let i=1; i<=12; i++) m+=`<option value="${String(i).padStart(2,'0')}">${i}월</option>`;
  for(let i=1; i<=31; i++) d+=`<option value="${String(i).padStart(2,'0')}">${i}일</option>`;
  document.getElementById('mem-birth-year').innerHTML = '<option value="">년도</option>' + y;
  document.getElementById('mem-birth-month').innerHTML = '<option value="">월</option>' + m;
  document.getElementById('mem-birth-day').innerHTML = '<option value="">일</option>' + d;
}

// 자동 로그인 및 보안 시스템
function switchAuthTab(t) { document.getElementById('tab-login').classList.remove('active'); document.getElementById('tab-signup').classList.remove('active'); document.getElementById('tab-'+t).classList.add('active'); document.getElementById('form-login').style.display = t==='login'?'block':'none'; document.getElementById('form-signup').style.display = t==='signup'?'block':'none'; }

async function handleSignup() {
  const n=document.getElementById('signup-name').value.trim(), r=document.getElementById('signup-role').value, p=document.getElementById('signup-pw').value, pc=document.getElementById('signup-pw-confirm').value;
  if(!n||!p||!pc)return showToast('정보를 모두 입력해 주세요.',true);
  if(!/^\d{4}$/.test(p)) return showToast('비밀번호는 반드시 숫자 4자리여야 합니다.', true);
  if(p !== pc) return showToast('비밀번호 확인이 서로 일치하지 않습니다.', true);

  showLoading(true);
  try{
    const e=await db.collection('auth_users').where('name','==',n).get();
    if(!e.empty){
      const existing = e.docs[0].data();
      if(existing.status === 'approved') showToast('💡 이미 가입 및 승인이 완료된 이름입니다. 로그인을 시도해 주세요.', true);
      else showToast('⏳ 이미 가입 신청되어 승인 대기 중인 이름입니다.', true);
      showLoading(false); return;
    }
    await db.collection('auth_users').add({name:n,role:r,pw:btoa(p),status:'pending',isAdmin:false});
    showToast('✅ 가입 신청이 접수되었습니다! 관리자 승인을 기다려주세요.');
    switchAuthTab('login');
  }catch(e){} showLoading(false);
}

async function handleLogin() {
  const n=document.getElementById('login-name').value.trim(), p=document.getElementById('login-pw').value; if(!n||!p)return showToast('정보를 입력하세요.',true); showLoading(true);
  try{
    if(n==='나상진'&&p==='0000'){ let o={name:'나상진',role:'아버지',pw:btoa('0000'),status:'approved',isAdmin:true}; const s=await db.collection('auth_users').where('name','==','나상진').get(); if(s.empty){const a=await db.collection('auth_users').add(o);o.id=a.id;}else{o.id=s.docs[0].id;await db.collection('auth_users').doc(o.id).update(o);} localStorage.setItem('fa_session',JSON.stringify(o)); startApp(o); return; }
    const s=await db.collection('auth_users').where('name','==',n).where('pw','==',btoa(p)).get(); if(s.empty){showToast('이름이나 비밀번호가 잘못되었습니다.',true);showLoading(false);return;}
    const u={id:s.docs[0].id,...s.docs[0].data()}; if(u.status==='pending')showToast('⏳ 아직 관리자 승인 대기 중입니다.',true); else{localStorage.setItem('fa_session',JSON.stringify(u));startApp(u);}
  }catch(e){} showLoading(false);
}
function logout() { localStorage.removeItem('fa_session'); location.reload(); }
async function checkAuth() {
  try { const adminCheck = await db.collection('auth_users').where('isAdmin', '==', true).get(); if(adminCheck.empty) await db.collection('auth_users').add({ name: '나상진', role: '아버지', pw: btoa('0000'), status: 'approved', isAdmin: true }); } catch(e) {}
  const s = localStorage.getItem('fa_session'); if(s) { const u=JSON.parse(s); startApp(u); db.collection('auth_users').doc(u.id).get().then(v=>{if(!v.exists||v.data().status!=='approved')logout();}); return; }
  document.getElementById('splash').classList.add('hidden'); document.getElementById('auth-overlay').style.display='flex';
}
function startApp(u) { CURRENT_USER=u; document.getElementById('auth-overlay').style.display='none'; document.getElementById('app').style.display='grid'; document.getElementById('splash').classList.add('hidden'); document.getElementById('topbar-user-info').innerHTML = `👤 ${u.name}님`; if(u.isAdmin) document.getElementById('menu-admin-wrap').style.display='block'; initDateSelects(); loadData(); }

// 클라우드 동기화
async function loadData() {
  showLoading(true, '동기화 중...');
  try {
    const [rs, ms] = await Promise.all([db.collection('records').get(), db.collection('family_members').get()]);
    GLOBAL_RECORDS = rs.docs.map(d=>({id:d.id,...d.data()})).sort((a,b)=>new Date(b.created)-new Date(a.created));
    GLOBAL_MEMBERS = ms.docs.map(d=>({id:d.id,...d.data()}));
    updateMemberSelects(); renderDashMembers(); renderGalleryFilters(); renderGallery('all'); renderRecent(); renderTimeline(); renderEvents(); if(CURRENT_USER.isAdmin) loadAdminList();
  } catch(e) {} showLoading(false);
}

function updateMemberSelects() { const h = GLOBAL_MEMBERS.map(m=>`<option value="${m.name}">${m.name} (${m.role})</option>`).join(''); document.getElementById('inp-person').innerHTML=h; document.getElementById('edit-person').innerHTML=h; }
function renderGalleryFilters() { let b = `<button class="add-member-btn" style="margin:0;font-size:0.85rem;" onclick="filterGallery('all')">전체</button>`; let set = new Set(); GLOBAL_MEMBERS.forEach(m => { if(!set.has(m.name)){ b+=`<button class="add-member-btn" style="margin:0;font-size:0.85rem;" onclick="filterGallery('${m.name}')">${m.name}</button>`; set.add(m.name); }}); document.getElementById('gallery-filters').innerHTML = b; }

// 인물 정렬 규칙 (나상진, 아내, 아들, 딸, 며느리, 손녀 순)
function getOrderScore(m) {
  const t = (m.name + ' ' + (m.role || '')).toLowerCase();
  if(t.includes('나상진') || t.includes('아버지')) return 1;
  if(t.includes('아내')) return 2;
  if(t.includes('아들')) return 3;
  if(t.includes('딸')) return 4;
  if(t.includes('며느리')) return 5;
  if(t.includes('손녀')) return 6;
  return 99;
}

function renderDashMembers() {
  document.getElementById('dash-direct').innerHTML = ''; document.getElementById('dash-paternal').innerHTML = ''; document.getElementById('dash-maternal').innerHTML = '';
  
  let sortedMembers = [...GLOBAL_MEMBERS].sort((a, b) => getOrderScore(a) - getOrderScore(b));

  sortedMembers.forEach(x => {
    let img = x.photoUrl ? `<img src="${x.photoUrl}">` : '👤';
    if(x.group==='직계가족') document.getElementById('dash-direct').innerHTML+=`<div class="family-card direct" onclick="openProfile('${x.id}')"><div class="avatar">${img}</div><div class="name">${x.name}</div><div class="role">${x.role}</div></div>`;
    else if(x.group==='친가') document.getElementById('dash-paternal').innerHTML+=`<span style="background:rgba(107,63,42,0.1);padding:6px 12px;border-radius:16px;font-size:0.85rem;margin-bottom:4px;cursor:pointer;display:inline-block;" onclick="openProfile('${x.id}')"><b>${x.name}</b> <small>${x.role}</small></span>`;
    else if(x.group==='처가') document.getElementById('dash-maternal').innerHTML+=`<span style="background:rgba(122,140,110,0.1);padding:6px 12px;border-radius:16px;font-size:0.85rem;margin-bottom:4px;cursor:pointer;display:inline-block;" onclick="openProfile('${x.id}')"><b>${x.name}</b> <small>${x.role}</small></span>`;
  });
}
function renderRecent() { document.getElementById('recent-events').innerHTML = GLOBAL_RECORDS.slice(0,5).map(generatePhotoHTML).join(''); }

// 🔒 권한 통제 시스템 적용
function generatePhotoHTML(r) {
  const rot = r.rotation||0; const scale = (rot%180!==0)?1.35:1; let tag='';
  if(r.fileType==='video') tag=`<video src="${r.imgUrl}#t=0.1" style="transform:rotate(${rot}deg) scale(${scale});"></video><div class="video-badge">▶️</div>`;
  else tag=`<img src="${r.imgUrl}" style="transform:rotate(${rot}deg) scale(${scale});">`;
  
  const hasPermission = (CURRENT_USER.isAdmin || r.author === CURRENT_USER.name);
  const act = hasPermission ? `<button onclick="rotateImg('${r.id}',${rot},this,event)">🔄</button><button onclick="openEditModal('${r.id}', event)">✏️</button><button onclick="deleteRecord('${r.id}','${r.imgUrl}',event)">🗑️</button>` : '';
  
  return `<div class="photo-card"><div class="card-actions">${act}</div><div class="photo-thumb" onclick="openLightbox('${r.id}')">${tag}</div><div class="photo-info" onclick="openLightbox('${r.id}')"><h4>${r.title}</h4><p class="memo-text">${r.memo||''}</p><div style="font-size:0.75rem;color:#888;margin-top:4px;">등록: ${r.author||'미지정'}</div></div></div>`;
}

function renderGallery(t) {
  let arr = (t==='all') ? GLOBAL_RECORDS : GLOBAL_RECORDS.filter(r=>r.person && r.person.includes(t));
  if(t==='직계가족' || t==='친가' || t==='처가') { const names = GLOBAL_MEMBERS.filter(m=>m.group===t).map(m=>m.name); arr = GLOBAL_RECORDS.filter(r=>names.some(n=>r.person&&r.person.includes(n))); }
  document.getElementById('photo-grid').innerHTML = arr.map(generatePhotoHTML).join('');
}
function searchRecords(v) { const q = v.toLowerCase(); document.getElementById('photo-grid').innerHTML = GLOBAL_RECORDS.filter(r=>(r.title||'').toLowerCase().includes(q)||(r.memo||'').toLowerCase().includes(q)||(r.person||'').toLowerCase().includes(q)).map(generatePhotoHTML).join(''); }

function renderTimeline() {
  let html=''; DECADES.forEach(dec=>{ const items = GLOBAL_RECORDS.filter(r=>getDecade(r.date)===dec.id); html+=`<div class="folder-card" onclick="this.classList.toggle('open')"><div class="folder-header"><div class="folder-title">⏳ ${dec.label}</div><div class="folder-count">${items.length}장</div></div><div class="folder-content" onclick="event.stopPropagation()">${items.length?`<div class="photo-grid" style="margin-top:10px;">${items.map(generatePhotoHTML).join('')}</div>`:'<p style="padding:10px;color:#888;">사진이 없습니다.</p>'}</div></div>`; });
  document.getElementById('timeline-container').innerHTML = html;
}
function renderEvents() {
  let html=''; EVENT_TYPES.forEach(ev=>{ const items = GLOBAL_RECORDS.filter(r=>r.event===ev.id); html+=`<div class="folder-card" onclick="this.classList.toggle('open')"><div class="folder-header"><div class="folder-title">${ev.label}</div><div class="folder-count">${items.length}장</div></div><div class="folder-content" onclick="event.stopPropagation()">${items.length?`<div class="photo-grid" style="margin-top:10px;">${items.map(generatePhotoHTML).join('')}</div>`:'<p style="padding:10px;color:#888;">사진이 없습니다.</p>'}</div></div>`; });
  document.getElementById('events-container').innerHTML = html;
}

// 라이트박스
function openLightbox(id) {
  const r=GLOBAL_RECORDS.find(x=>x.id===id); if(!r)return; const rot=r.rotation||0; const tr=`transform:rotate(${rot}deg);`;
  let m = r.fileType==='video'?`<video src="${r.imgUrl}" controls autoplay style="${tr} max-width:100%;max-height:85vh;"></video>`:`<img src="${r.imgUrl}" style="${tr} max-width:100%;max-height:85vh;object-fit:contain;">`;
  document.getElementById('lightbox-media').innerHTML=m; document.getElementById('lightbox-caption').innerHTML=`<b>${r.title}</b><br><span style="color:#ccc;">${r.memo||''}</span><br><small style="color:#aaa;">날짜: ${r.date||''} / 작성자: ${r.author||''}</small>`;
  document.getElementById('lightbox-overlay').classList.add('open');
}
function closeLightbox(e) { if(e.target.id==='lightbox-overlay'||e.target.classList.contains('lightbox-close')){document.getElementById('lightbox-media').innerHTML=''; document.getElementById('lightbox-overlay').classList.remove('open');} }

// 👤 가족 상세 프로필 열기 
function openProfile(id) {
  const m = GLOBAL_MEMBERS.find(x => x.id === id); if(!m) return;
  const imgHtml = m.photoUrl ? `<img src="${m.photoUrl}" style="width:120px;height:120px;border-radius:50%;object-fit:cover;margin:0 auto 15px;display:block;box-shadow:0 4px 10px rgba(0,0,0,0.2);">` : `<div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,var(--brown-light),var(--gold));margin:0 auto 15px;display:flex;align-items:center;justify-content:center;font-size:3rem;color:#fff;">👤</div>`;
  
  let linkHtml = '기록이 없습니다.';
  if (m.link) linkHtml = `<a href="${m.link}" target="_blank" style="color:#0066cc; text-decoration:underline;">바로가기 클릭</a>`;

  const html = `
    <div style="text-align:center;">
      ${imgHtml}
      <h2 style="color:var(--brown-deep); margin-bottom:5px;">${m.name} <span style="font-size:1rem;color:var(--text-sub);">(${m.role})</span></h2>
      <p style="color:var(--brown-light); font-size:0.9rem; margin-bottom:20px;">생년월일: ${m.birthDate || '미상'}</p>
    </div>
    <div style="background:var(--cream); padding:15px; border-radius:12px; margin-bottom:15px;">
      <h4 style="color:var(--brown-mid); margin-bottom:8px; border-bottom:1px solid rgba(44,26,14,0.1); padding-bottom:4px;">🎓 학력</h4>
      <p style="font-size:0.9rem; white-space:pre-wrap;">${m.edu || '기록이 없습니다.'}</p>
    </div>
    <div style="background:var(--cream); padding:15px; border-radius:12px; margin-bottom:15px;">
      <h4 style="color:var(--brown-mid); margin-bottom:8px; border-bottom:1px solid rgba(44,26,14,0.1); padding-bottom:4px;">💼 주요 경력</h4>
      <p style="font-size:0.9rem; white-space:pre-wrap;">${m.career || '기록이 없습니다.'}</p>
    </div>
    <div style="background:var(--cream); padding:15px; border-radius:12px; margin-bottom:15px;">
      <h4 style="color:var(--brown-mid); margin-bottom:8px; border-bottom:1px solid rgba(44,26,14,0.1); padding-bottom:4px;">🔗 링크 (블로그/동영상)</h4>
      <p style="font-size:0.9rem;">${linkHtml}</p>
    </div>
    <div style="background:var(--cream); padding:15px; border-radius:12px; margin-bottom:15px;">
      <h4 style="color:var(--brown-mid); margin-bottom:8px; border-bottom:1px solid rgba(44,26,14,0.1); padding-bottom:4px;">✉️ 편지 및 참고사항</h4>
      <p style="font-size:0.9rem; white-space:pre-wrap; line-height:1.5;">${m.note || '기록이 없습니다.'}</p>
    </div>
    ${(CURRENT_USER.isAdmin) ? `<div style="text-align:center; margin-top:20px;"><button class="btn-primary" onclick="editMember('${m.id}')" style="width:auto; padding:10px 24px;">✏️ 프로필 수정하기</button></div>` : ''}
  `;
  document.getElementById('profile-content').innerHTML = html;
  document.getElementById('modal-profile').classList.add('open');
}

// 인물 등록 및 관리
let tempMemFile = null;
function openMemberModal(g) { 
  document.getElementById('mem-edit-id').value=''; document.getElementById('mem-group').value=g; document.getElementById('mem-name').value=''; 
  document.getElementById('mem-birth-year').value=''; document.getElementById('mem-birth-month').value=''; document.getElementById('mem-birth-day').value=''; 
  document.getElementById('mem-role').value=''; document.getElementById('mem-edu').value=''; document.getElementById('mem-career').value=''; 
  document.getElementById('mem-link').value=''; document.getElementById('mem-note').value='';
  document.getElementById('member-img-preview').innerHTML='📷'; tempMemFile=null; document.getElementById('modal-member').classList.add('open'); 
}
function closeMemberModal() { document.getElementById('modal-member').classList.remove('open'); }
function previewMemberPhoto(inp) { if(inp.files&&inp.files[0]){ tempMemFile=inp.files[0]; const r=new FileReader(); r.onload=e=>document.getElementById('member-img-preview').innerHTML=`<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;">`; r.readAsDataURL(tempMemFile); } }

async function saveMember() {
  const id=document.getElementById('mem-edit-id').value, n=document.getElementById('mem-name').value.trim();
  const y=document.getElementById('mem-birth-year').value, m=document.getElementById('mem-birth-month').value, d=document.getElementById('mem-birth-day').value, bd=(y&&m&&d)?`${y}-${m}-${d}`:'';
  const g=document.getElementById('mem-group').value, r=document.getElementById('mem-role').value.trim();
  const edu=document.getElementById('mem-edu').value.trim(), career=document.getElementById('mem-career').value.trim(), link=document.getElementById('mem-link').value.trim(), note=document.getElementById('mem-note').value.trim();
  
  if(!n) return showToast('이름을 입력하세요.',true); showLoading(true);
  try{ let u=''; if(tempMemFile){ const rf=firebase.storage().ref('profiles/'+Date.now()+'_'+tempMemFile.name); await rf.put(tempMemFile); u=await rf.getDownloadURL(); }
    let obj = {name:n, birthDate:bd, group:g, role:r, edu:edu, career:career, link:link, note:note}; if(u) obj.photoUrl=u;
    if(id) await db.collection('family_members').doc(id).update(obj); else await db.collection('family_members').add(obj);
    showToast('가족 정보가 저장되었습니다.'); closeMemberModal(); document.getElementById('modal-profile').classList.remove('open'); loadData();
  }catch(e){} showLoading(false);
}

function openManageMembersModal() {
  let h = ''; GLOBAL_MEMBERS.forEach(m => { h += `<div class="member-list-item"><div><b>${m.name}</b> <span style="color:#888;">(${m.group}/${m.role})</span></div><div class="member-list-actions"><button onclick="editMember('${m.id}')">수정</button><button onclick="deleteMember('${m.id}')" style="color:var(--rust);">삭제</button></div></div>`; });
  document.getElementById('manage-members-list').innerHTML = h || '<p>등록된 가족이 없습니다.</p>'; document.getElementById('modal-manage-members').classList.add('open');
}
function editMember(id) { 
  const m = GLOBAL_MEMBERS.find(x=>x.id===id); if(!m)return; 
  document.getElementById('mem-edit-id').value = id; document.getElementById('mem-name').value = m.name; document.getElementById('mem-group').value = m.group; document.getElementById('mem-role').value = m.role; 
  document.getElementById('mem-edu').value = m.edu || ''; document.getElementById('mem-career').value = m.career || ''; document.getElementById('mem-link').value = m.link || ''; document.getElementById('mem-note').value = m.note || '';
  if(m.birthDate) { const pts = m.birthDate.split('-'); document.getElementById('mem-birth-year').value = pts[0]||''; document.getElementById('mem-birth-month').value = pts[1]||''; document.getElementById('mem-birth-day').value = pts[2]||''; } 
  document.getElementById('member-img-preview').innerHTML = m.photoUrl ? `<img src="${m.photoUrl}" style="width:100%;height:100%;object-fit:cover;">` : '📷'; 
  document.getElementById('modal-manage-members').classList.remove('open'); document.getElementById('modal-profile').classList.remove('open'); document.getElementById('modal-member').classList.add('open'); 
}
async function deleteMember(id) { if(!confirm('이 가족 인물을 삭제하시겠습니까?')) return; showLoading(true); try{ await db.collection('family_members').doc(id).delete(); showToast('삭제 완료'); await loadData(); openManageMembersModal(); }catch(e){} showLoading(false); }

// 업로드 관리
function openUpload() { document.getElementById('modal-upload').classList.add('open'); document.getElementById('inp-file').value=''; document.getElementById('file-preview-name').textContent='선택 안됨'; document.getElementById('inp-title').value=''; document.getElementById('inp-memo').value=''; document.getElementById('inp-date').value=new Date().toISOString().slice(0,10); }
function closeUpload() { document.getElementById('modal-upload').classList.remove('open'); }
function previewUploadFiles(inp) { document.getElementById('file-preview-name').innerHTML = inp.files.length?`✅ <b>${inp.files.length}개</b> 파일 선택됨`:'선택 안됨'; }

async function saveRecord() {
  const t=document.getElementById('inp-title').value.trim(), m=document.getElementById('inp-memo').value.trim(), f=document.getElementById('inp-file'); if(!t)return showToast('제목을 입력하세요.',true); if(!f.files.length)return showToast('파일을 선택하세요.',true);
  const fs=Array.from(f.files); const tot=fs.length; showLoading(true, `클라우드 업로드 중... 1/${tot}`);
  try {
    for(let i=0; i<tot; i++){
      showLoading(true, `클라우드 저장 중... ${i+1}/${tot}`); const fl=fs[i]; const isVid = fl.type.startsWith('video/') || fl.name.match(/\.(mp4|mov|webm|avi)$/i);
      const rf=firebase.storage().ref('photos/'+Date.now()+'_'+fl.name); await rf.put(fl); const u=await rf.getDownloadURL();
      await db.collection('records').add({ title:tot>1?`${t} (${i+1})`:t, memo:m, imgUrl:u, fileType:isVid?'video':'image', date:document.getElementById('inp-date').value, event:document.getElementById('inp-event').value, person:[...document.getElementById('inp-person').selectedOptions].map(o=>o.value).join(', '), rotation:0, author:CURRENT_USER.name, created:new Date().toISOString() });
    }
    closeUpload(); await loadData(); showToast('저장 성공!');
  }catch(e){} showLoading(false);
}

// 회전 백엔드 검증
async function rotateImg(id, cur, btn, ev) {
  ev.stopPropagation(); const r = GLOBAL_RECORDS.find(x => x.id === id); if(!r) return;
  if(!CURRENT_USER.isAdmin && r.author !== CURRENT_USER.name) { return showToast('🚫 다른 사람이 올린 사진은 제어할 수 없습니다.', true); }
  const n=(cur+90)%360; btn.closest('.photo-card').querySelector('img, video').style.transform=`rotate(${n}deg) scale(${n%180!==0?1.35:1})`; btn.setAttribute('onclick',`rotateImg('${id}',${n},this,event)`);
  db.collection('records').doc(id).update({rotation:n});
}

// 수정 백엔드 검증
function openEditModal(id, ev) {
  ev.stopPropagation(); const r=GLOBAL_RECORDS.find(x=>x.id===id); if(!r)return;
  if(!CURRENT_USER.isAdmin && r.author !== CURRENT_USER.name) { return showToast('🚫 다른 사람이 올린 자료는 수정할 수 없습니다.', true); }
  currentEditId=id; document.getElementById('edit-title').value=r.title||''; document.getElementById('edit-date').value=r.date||''; document.getElementById('edit-memo').value=r.memo||''; document.getElementById('edit-event').value=r.event||'daily';
  const sel=document.getElementById('edit-person'); const ps=(r.person||'').split(', '); for(let i=0;i<sel.options.length;i++) sel.options[i].selected = ps.includes(sel.options[i].value);
  document.getElementById('modal-edit').classList.add('open');
}
function closeEditModal() { document.getElementById('modal-edit').classList.remove('open'); }

async function updateRecord() {
  if(!currentEditId)return; const t=document.getElementById('edit-title').value.trim(); if(!t)return showToast('제목 필수',true);
  const r = GLOBAL_RECORDS.find(x => x.id === currentEditId); if(!CURRENT_USER.isAdmin && r.author !== CURRENT_USER.name) { showToast('권한이 없습니다.', true); closeEditModal(); return; }
  showLoading(true);
  try{ await db.collection('records').doc(currentEditId).update({ title:t, date:document.getElementById('edit-date').value, memo:document.getElementById('edit-memo').value.trim(), event:document.getElementById('edit-event').value, person:[...document.getElementById('edit-person').selectedOptions].map(o=>o.value).join(', ') }); closeEditModal(); await loadData(); showToast('수정 완료!'); }catch(e){} showLoading(false);
}

// 삭제 백엔드 검증
async function deleteRecord(id, url, ev) {
  ev.stopPropagation(); const r = GLOBAL_RECORDS.find(x => x.id === id); if(!r) return;
  if(!CURRENT_USER.isAdmin && r.author !== CURRENT_USER.name) { return showToast('🚫 다른 사람이 올린 자료는 삭제할 수 없습니다.', true); }
  if(!confirm("이 기록을 클라우드에서 영구 삭제하시겠습니까?"))return; showLoading(true);
  try{ await db.collection('records').doc(id).delete(); if(url&&url.includes('firebase'))await firebase.storage().refFromURL(url).delete(); await loadData(); showToast('삭제 완료'); }catch(e){} showLoading(false);
}

// 가입 승인 대기열
async function loadAdminList() { const e=document.getElementById('admin-user-list'), s=await db.collection('auth_users').where('status','==','pending').get(); if(s.empty)return e.innerHTML='<p style="padding:20px; text-align:center;">승인 대기 중인 신청자가 없습니다.</p>'; e.innerHTML=s.docs.map(d=>`<div style="display:flex;justify-content:space-between;align-items:center;background:#fff;padding:15px;margin-bottom:10px;border-radius:8px;border:1px solid #eee;"><div><b>${d.data().name}</b> [<span style="color:var(--brown-light);">${d.data().role}</span>]</div><button class="topbar-btn" onclick="approveUser('${d.id}')">✅ 가입 승인하기</button></div>`).join(''); }
async function approveUser(id) { await db.collection('auth_users').doc(id).update({status:'approved'}); showToast('가족 가입 승인이 완료되었습니다!'); loadData(); }

// 네비게이션
function showPage(id) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.getElementById('page-'+id).classList.add('active');
  const m={'dashboard':'대시보드', 'gallery':'전체 갤러리', 'timeline':'연대 타임라인', 'events':'이벤트 파일', 'admin':'가족 승인 관리'}; document.getElementById('bc-current').textContent = m[id]||'';
  if(window.innerWidth<=768 && document.getElementById('sidebar').classList.contains('open')) toggleSidebar();
}
function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); }
function closeModal(e, id) { if(e.target.id===id) document.getElementById(id).classList.remove('open'); }

checkAuth();
</script>
